# OpenAI API Key (required for Analyst Agent and Chat features)
OPENAI_API_KEY=sk-your-key-here

# Database
DATABASE_URL=sqlite:///./data/cybersecurity.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-this-to-a-random-secret

# Detection Settings
DETECTION_CONTAMINATION=0.1
ANOMALY_THRESHOLD_ZSCORE=3.0
FAILED_LOGIN_THRESHOLD=5
UNUSUAL_HOUR_START=2
UNUSUAL_HOUR_END=5

# Streamlit
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000
